# OpenUI environment variables — copy to `.env` and fill in real values.
# `.env` is git-ignored; NEVER commit real keys. All secrets are read in the
# Electron MAIN process only and are never exposed to the renderer.

# ── Analytics: PostHog (optional — telemetry is silently disabled when unset) ─
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com   # override for EU cloud or self-hosted

# ── Ollama — THE AI ENGINE (required) ─────────────────────────────────────────
# OpenUI runs entirely on a local / self-hosted Ollama server. ALL chat, planning
# and agent runs stream from here — there are NO cloud LLM calls, no API keys, and
# no credit balance that can run out. Every tier (free/pro/enterprise) uses it.
#
# Setup (once):
#   1. Install Ollama:  https://ollama.com/download
#   2. Start the server: ollama serve
#   3. Pull the model:   ollama pull llama3:8b
#
# OLLAMA_HOST points the app at the server. For a shared/remote server that serves
# your users, set OLLAMA_HOST to that machine's URL (e.g. http://your-server:11434)
# and start it with `OLLAMA_HOST=0.0.0.0:11434 ollama serve` so it accepts LAN
# connections. OLLAMA_MODEL selects which pulled model to use.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# ── Supabase (authentication + subscriptions backend) ─────────────────────────
# The Electron app uses ONLY the anon (publishable) key — safe to ship. It never
# holds the service-role key or any Stripe secret; those live exclusively in
# Supabase Edge Function secrets (see supabase/functions/README.md).
# Project URL + anon key: https://app.supabase.com → Project Settings → API
# In Supabase Auth → URL Configuration, add `openui://auth-callback` to the
# allowed redirect URLs, and enable the Google provider.
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe PRICE ids (NOT secret — these are public, like a SKU) ──────────────
# Used to tell the create-checkout Edge Function which plan the user picked, and
# to display pricing. The Stripe SECRET key is NEVER set here.
#
# VITE_-prefixed copies are inlined into the renderer bundle by Vite so that
# TierUpgradeModal can read them via import.meta.env at runtime.
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id
VITE_STRIPE_PRO_PRICE_ID=price_your_pro_price_id
VITE_STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# ── Mailchimp waitlist (Supabase Edge Function secrets — NOT app env) ─────────
# The website's "Join the waitlist" form posts to the `waitlist` Edge Function,
# which calls Mailchimp server-side. The API key is a SECRET and, like the Stripe
# secret, lives ONLY in the Supabase Edge Function — the Electron app never reads
# these. They are listed here for reference; set them with:
#   supabase secrets set MAILCHIMP_API_KEY=xxx MAILCHIMP_SERVER_PREFIX=us1 MAILCHIMP_LIST_ID=xxx
# - API key:       Mailchimp → Account → Extras → API keys → Create A Key
# - Server prefix: the "usN" in your dashboard URL / after the dash in the API key
# - List/Audience ID: Audience → Settings → "Unique ID for this audience"
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your-mailchimp-audience-id

# ── Telemetry: PostHog (optional — telemetry is silently disabled when unset) ─
# Get an API key at https://us.posthog.com/ (free tier: 1M events/month)
# POSTHOG_API_KEY=phc_your-posthog-project-api-key
# POSTHOG_HOST=https://us.i.posthog.com

# ── Dev only (optional) ───────────────────────────────────────────────────────
# Seeds the "signed-in user" before real Supabase auth is wired, so the checkout/
# sync flow can be exercised locally. Leave unset in production.
# OPENUI_DEV_USER_ID=

# ── Multi-User Server (server/main.py + docker-compose.yml) ──────────────────
# These are used by the FastAPI backend; they are NOT read by the Electron app.
DATABASE_URL=postgresql+asyncpg://openui:openui@postgres:5432/openui
REDIS_URL=redis://redis:6379
# SUPABASE_SERVICE_ROLE_KEY is server-side only — NEVER ship to the client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ──────────────────────────────────────────────────────────────────────────────
# NEVER put these in this file (or anywhere in the Electron app):
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SIGNING_SECRET, SUPABASE_SERVICE_ROLE_KEY
# They belong only to the Supabase Edge Functions.
#
# Chat needs NO LLM keys anywhere — client or server. Every turn runs on the local
# Ollama server (see the Ollama section at the top). Supabase/Stripe here only
# power optional sign-in + subscriptions, not the AI itself.
# ──────────────────────────────────────────────────────────────────────────────
