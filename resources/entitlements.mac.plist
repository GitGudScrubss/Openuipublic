<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for notarized macOS builds (electron-builder
  `mac.entitlements` / `mac.entitlementsInherit`, see package.json).

  Electron itself needs the four `com.apple.security.cs.*` exceptions below —
  without them the hardened-runtime binary crashes on launch (V8 JIT requires
  writable+executable pages, which the runtime blocks by default). The two
  `device.*` entitlements gate the microphone permission prompt (push-to-talk
  voice input, Whisper). Screen Recording (`read_screen()` via desktopCapturer)
  has no entitlement key of its own — macOS gates it purely through TCC
  (System Settings → Privacy & Security → Screen Recording), checked at
  runtime via systemPreferences.getMediaAccessStatus('screen'); nothing to
  declare here. Nothing else is requested — no camera, no Apple Events/
  AppleScript entitlement is needed since `osascript` is invoked as a
  subprocess, not via the Scripting Bridge.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.device.microphone</key>
	<true/>
</dict>
</plist>
